generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  admin
  asset_manager
  department_head
  employee
}

enum RecordStatus {
  active
  inactive
}

model Department {
  id        String       @id @default(uuid())
  name      String       @unique
  status    RecordStatus @default(active)
  createdAt DateTime     @default(now()) @map("created_at")

  @@map("departments")
}

model User {
  id           String       @id @default(uuid())
  name         String
  email        String       @unique
  passwordHash String       @map("password_hash")
  role         UserRole     @default(employee)
  status       RecordStatus @default(active)
  createdAt    DateTime     @default(now()) @map("created_at")

  @@map("users")
}